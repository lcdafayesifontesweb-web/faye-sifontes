# Sanity.io — SS Consultores
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Token con permisos de escritura (Editor) para registrar inscripciones
# Crear en: sanity.io/manage → API → Tokens
SANITY_API_TOKEN=

# Alertas de inscripción (Resend)
RESEND_API_KEY=

# Asistente virtual (Google Gemini)
GEMINI_API_KEY=
# Modelo fijado en route.ts: gemini-3.1-flash-lite (v1beta)
